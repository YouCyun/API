# ========================================
# 資料庫設定 (PostgreSQL)
# ========================================
# DB_TYPE=disabled → 跳過 TypeORM，可在未架設 DB 的情況下啟動看 Swagger
# DB_TYPE=postgres → 正式連線 PostgreSQL
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=mles2266
DB_DATABASE=TEST

# ========================================
# AIMaker 第三方平台設定
# ========================================
AIMAKER_BASE_URL=https://aimaker.com.tw
AIMAKER_EMAIL=device@hsnl.cs.nthu.edu.tw
AIMAKER_PASSWORD=1qaz@WSX3edc

# AIMaker 工作階段 Cookie 在後端記憶體的快取時效 (毫秒)
# 預設 23 小時 (82800000 ms)，略短於 AIMaker 24 小時 Session 有效期
AIMAKER_SESSION_TTL_MS=82800000

# ========================================
# 應用程式設定
# ========================================
PORT=3000
NODE_ENV=development
