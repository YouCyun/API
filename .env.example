# ========================================
# 資料庫設定 (PostgreSQL)
# ========================================
#
# DB_TYPE 可選値：
#   postgres  - 開啟資料庫連線（正式 / 已架設 PostgreSQL）
#   disabled  - 跳過 TypeORM，應用程序仍會啟動（供開發階段瀏覽 Swagger 用）
#
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=mles2266
DB_DATABASE=TEST

# ========================================
# AIMaker 第三方平台設定
# ========================================
AIMAKER_BASE_URL=https://aimaker.com.tw
AIMAKER_EMAIL=your_aimaker_email@example.com
AIMAKER_PASSWORD=your_aimaker_password

# AIMaker 工作階段 Cookie 在後端記憶體的快取時效 (毫秒)
# 預設 23 小時 (82800000 ms)，略短於 AIMaker 24 小時 Session 有效期
AIMAKER_SESSION_TTL_MS=82800000

# ========================================
# 應用程式設定
# ========================================
PORT=3000
NODE_ENV=development
